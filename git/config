[user]
	name =  # user.name
	email = # user.email

[core]
	editor = vim
	# editor =  \"C:/Program Files/Vim/vim92/vim.exe\"
	filemode = false
	pager = delta
	# autocrlf = true    # enable this line in Windows

[interactive]
	diffFilter = delta --color-only

[tig]
	main-view-id = yes
	main-view-date = custom
	main-view-date-format = "%y%m%d"
	main-view-author = abbreviated
	tab-size = 4

[tig "bind"]
	generic = D >git show --patch-with-stat %(commit)

[delta]
	navigate = true
	light = true
	side-by-side = true
	line-numbers = true
	wrap-max-lines = 0

[diff]
	tool = vimdiff
	# tool = winmerge

[difftool "winmerge"]
	cmd = \"$LOCALAPPDATA/Programs/WinMerge/WinMergeU.exe\" -u -e \"$LOCAL\" \"$REMOTE\"

